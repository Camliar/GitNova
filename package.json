{
  "name": "gitnova",
  "version": "0.0.0",
  "private": true,
  "description": "GitNova monorepo foundation",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "generate:protocol": "node scripts/generate-protocol.mjs",
    "check:protocol": "node scripts/generate-protocol.mjs --check",
    "check:desktop": "pnpm --filter @gitnova/desktop check",
    "check": "npm run check:protocol && npm run check:desktop"
  }
}
