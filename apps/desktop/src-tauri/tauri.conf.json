{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitNova",
  "version": "0.1.0",
  "identifier": "dev.gitnova.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "GitNova",
        "width": 1180,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
