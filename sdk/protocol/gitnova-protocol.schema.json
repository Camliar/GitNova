{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitnova.dev/schema/protocol/1.12/gitnova-protocol.schema.json",
  "title": "GitNova Core Protocol 1.12",
  "type": "object",
  "properties": { "protocolVersion": { "const": "1.12" } },
  "required": ["protocolVersion"],
  "$defs": {
    "RequestId": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
    "ImplementationInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "name": { "type": "string" }, "version": { "type": "string" } },
      "required": ["name", "version"]
    },
    "ClientCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "cancellation": { "type": "boolean", "default": false } }
    },
    "ServerCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cancellation": { "type": "boolean" },
        "repositoryDiscovery": { "type": "boolean" },
        "workingTreeStatus": { "type": "boolean" },
        "structuredFileDiff": { "type": "boolean" },
        "paginatedCommitHistory": { "type": "boolean" },
        "structuredCommitDiff": { "type": "boolean" },
        "repositoryReferences": { "type": "boolean" },
        "commitGraphProjection": { "type": "boolean" },
        "githubRepository": { "type": "boolean" },
        "githubPullRequest": { "type": "boolean" },
        "githubPullRequestCommitDiff": { "type": "boolean" },
        "githubSquashTrace": { "type": "boolean" },
        "repositoryMutations": { "type": "boolean" }
      },
      "required": ["cancellation", "repositoryDiscovery", "workingTreeStatus", "structuredFileDiff", "paginatedCommitHistory", "structuredCommitDiff", "repositoryReferences", "commitGraphProjection", "githubRepository", "githubPullRequest", "githubPullRequestCommitDiff", "githubSquashTrace", "repositoryMutations"]
    },
    "InitializeParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clientInfo": { "$ref": "#/$defs/ImplementationInfo" },
        "protocolVersion": { "type": "string" },
        "capabilities": { "$ref": "#/$defs/ClientCapabilities" }
      },
      "required": ["clientInfo", "protocolVersion"]
    },
    "InitializeResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coreInfo": { "$ref": "#/$defs/ImplementationInfo" },
        "protocolVersion": { "type": "string" },
        "capabilities": { "$ref": "#/$defs/ServerCapabilities" }
      },
      "required": ["coreInfo", "protocolVersion", "capabilities"]
    },
    "CancelParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "id": { "$ref": "#/$defs/RequestId" } },
      "required": ["id"]
    },
    "ErrorData": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stableCode": { "type": "string" },
        "retryable": { "type": "boolean" },
        "details": { "type": "object", "additionalProperties": true }
      },
      "required": ["stableCode", "retryable"]
    },
    "RepositoryPathParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "path": { "type": "string", "minLength": 1 } },
      "required": ["path"]
    },
    "RepositoryKind": {
      "enum": ["worktree", "linkedWorktree", "bare"]
    },
    "RepositoryDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "worktreeRoot": { "type": ["string", "null"] },
        "gitDirectory": { "type": "string" },
        "commonGitDirectory": { "type": "string" },
        "kind": { "$ref": "#/$defs/RepositoryKind" },
        "gitVersion": { "type": "string" }
      },
      "required": ["worktreeRoot", "gitDirectory", "commonGitDirectory", "kind", "gitVersion"]
    },
    "StatusEntryKind": {
      "enum": ["ordinary", "renameOrCopy", "unmerged", "untracked"]
    },
    "FileStatus": {
      "enum": ["unmodified", "modified", "added", "deleted", "renamed", "copied", "unmerged", "untracked", "typeChanged", "unknown"]
    },
    "StatusEntry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "originalPath": { "type": ["string", "null"] },
        "kind": { "$ref": "#/$defs/StatusEntryKind" },
        "indexStatus": { "$ref": "#/$defs/FileStatus" },
        "worktreeStatus": { "$ref": "#/$defs/FileStatus" }
      },
      "required": ["path", "originalPath", "kind", "indexStatus", "worktreeStatus"]
    },
    "BranchStatus": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "head": { "type": ["string", "null"] },
        "oid": { "type": ["string", "null"] },
        "upstream": { "type": ["string", "null"] },
        "ahead": { "type": "integer", "minimum": 0 },
        "behind": { "type": "integer", "minimum": 0 }
      },
      "required": ["head", "oid", "upstream", "ahead", "behind"]
    },
    "WorkingTreeStatus": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "branch": { "$ref": "#/$defs/BranchStatus" },
        "entries": { "type": "array", "items": { "$ref": "#/$defs/StatusEntry" } }
      },
      "required": ["branch", "entries"]
    },
    "DiffScope": { "enum": ["workingTree", "staged"] },
    "DiffParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/DiffScope" },
        "contextLines": { "type": "integer", "minimum": 0, "maximum": 20 }
      },
      "required": ["path", "scope"]
    },
    "DiffLineKind": { "enum": ["context", "addition", "deletion"] },
    "DiffLine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "$ref": "#/$defs/DiffLineKind" },
        "content": { "type": "string" },
        "oldLine": { "type": ["integer", "null"], "minimum": 0 },
        "newLine": { "type": ["integer", "null"], "minimum": 0 }
      },
      "required": ["kind", "content", "oldLine", "newLine"]
    },
    "DiffHunk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oldStart": { "type": "integer", "minimum": 0 },
        "oldLines": { "type": "integer", "minimum": 0 },
        "newStart": { "type": "integer", "minimum": 0 },
        "newLines": { "type": "integer", "minimum": 0 },
        "header": { "type": "string" },
        "lines": { "type": "array", "items": { "$ref": "#/$defs/DiffLine" } }
      },
      "required": ["oldStart", "oldLines", "newStart", "newLines", "header", "lines"]
    },
    "FileDiff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oldPath": { "type": "string" },
        "newPath": { "type": "string" },
        "isBinary": { "type": "boolean" },
        "hunks": { "type": "array", "items": { "$ref": "#/$defs/DiffHunk" } }
      },
      "required": ["oldPath", "newPath", "isBinary", "hunks"]
    },
    "HistoryParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limit": { "type": "integer", "minimum": 1, "maximum": 200 },
        "cursor": { "type": "string", "minLength": 1 }
      }
    },
    "CommitIdentity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "timestamp"]
    },
    "CommitSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oid": { "type": "string" },
        "parents": { "type": "array", "items": { "type": "string" } },
        "author": { "$ref": "#/$defs/CommitIdentity" },
        "committer": { "$ref": "#/$defs/CommitIdentity" },
        "summary": { "type": "string" },
        "message": { "type": "string" }
      },
      "required": ["oid", "parents", "author", "committer", "summary", "message"]
    },
    "HistoryPage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commits": { "type": "array", "items": { "$ref": "#/$defs/CommitSummary" } },
        "nextCursor": { "type": ["string", "null"] }
      },
      "required": ["commits", "nextCursor"]
    },
    "CommitDiffParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oid": { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" },
        "parentOid": { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" },
        "contextLines": { "type": "integer", "minimum": 0, "maximum": 20 }
      },
      "required": ["oid"]
    },
    "CommitDiff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commit": { "$ref": "#/$defs/CommitSummary" },
        "parentOid": { "type": ["string", "null"] },
        "files": { "type": "array", "items": { "$ref": "#/$defs/FileDiff" } }
      },
      "required": ["commit", "parentOid", "files"]
    },
    "ReferenceKind": {
      "enum": ["localBranch", "remoteBranch", "tag"]
    },
    "RepositoryHead": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oid": { "type": ["string", "null"] },
        "symbolicRef": { "type": ["string", "null"] }
      },
      "required": ["oid", "symbolicRef"]
    },
    "RepositoryReference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "fullName": { "type": "string" },
        "kind": { "$ref": "#/$defs/ReferenceKind" },
        "targetOid": { "type": "string" },
        "peeledTargetOid": { "type": ["string", "null"] },
        "symbolicTarget": { "type": ["string", "null"] },
        "upstream": { "type": ["string", "null"] }
      },
      "required": ["name", "fullName", "kind", "targetOid", "peeledTargetOid", "symbolicTarget", "upstream"]
    },
    "RepositoryReferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "head": { "$ref": "#/$defs/RepositoryHead" },
        "references": { "type": "array", "items": { "$ref": "#/$defs/RepositoryReference" } }
      },
      "required": ["head", "references"]
    },
    "CommitGraphNode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commit": { "$ref": "#/$defs/CommitSummary" },
        "isHead": { "type": "boolean" },
        "references": { "type": "array", "items": { "$ref": "#/$defs/RepositoryReference" } }
      },
      "required": ["commit", "isHead", "references"]
    },
    "CommitGraphPage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/CommitGraphNode" } },
        "nextCursor": { "type": ["string", "null"] }
      },
      "required": ["nodes", "nextCursor"]
    },
    "CommitParams": {
      "type": "object", "additionalProperties": false,
      "properties": { "message": { "type": "string", "minLength": 1, "maxLength": 65536 } },
      "required": ["message"]
    },
    "BranchParams": {
      "type": "object", "additionalProperties": false,
      "properties": { "name": { "type": "string", "minLength": 1, "maxLength": 255 } },
      "required": ["name"]
    },
    "RepositoryMutationSnapshot": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "status": { "$ref": "#/$defs/WorkingTreeStatus" },
        "references": { "$ref": "#/$defs/RepositoryReferences" }
      }, "required": ["status", "references"]
    },
    "CommitResult": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "commit": { "$ref": "#/$defs/CommitSummary" },
        "snapshot": { "$ref": "#/$defs/RepositoryMutationSnapshot" }
      }, "required": ["commit", "snapshot"]
    },
    "GitHubRepositoryParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "remote": { "type": "string", "minLength": 1, "maxLength": 255 },
        "nameWithOwner": { "type": "string", "minLength": 3, "maxLength": 140 }
      }
    },
    "GitHubRepository": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "const": "github.com" },
        "owner": { "type": "string" },
        "name": { "type": "string" },
        "nameWithOwner": { "type": "string" },
        "url": { "type": "string" },
        "defaultBranch": { "type": "string" },
        "isPrivate": { "type": "boolean" }
      },
      "required": ["host", "owner", "name", "nameWithOwner", "url", "defaultBranch", "isPrivate"]
    },
    "GitHubPullRequestParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "remote": { "type": "string", "minLength": 1, "maxLength": 255 },
        "nameWithOwner": { "type": "string", "minLength": 3, "maxLength": 140 }
      },
      "required": ["number"]
    },
    "GitHubPullRequestState": { "enum": ["open", "closed", "merged"] },
    "GitHubPullRequestRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "oid": { "type": "string" },
        "repository": { "type": ["string", "null"] }
      },
      "required": ["name", "oid", "repository"]
    },
    "GitHubCommitIdentity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "login": { "type": ["string", "null"] }
      },
      "required": ["name", "email", "timestamp", "login"]
    },
    "GitHubPullRequestCommit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oid": { "type": "string" },
        "parents": { "type": "array", "items": { "type": "string" } },
        "author": { "$ref": "#/$defs/GitHubCommitIdentity" },
        "committer": { "$ref": "#/$defs/GitHubCommitIdentity" },
        "summary": { "type": "string" },
        "message": { "type": "string" },
        "url": { "type": "string" }
      },
      "required": ["oid", "parents", "author", "committer", "summary", "message", "url"]
    },
    "GitHubPullRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "const": "github.com" },
        "nameWithOwner": { "type": "string" },
        "number": { "type": "integer", "minimum": 1 },
        "title": { "type": "string" },
        "body": { "type": ["string", "null"] },
        "state": { "$ref": "#/$defs/GitHubPullRequestState" },
        "isDraft": { "type": "boolean" },
        "authorLogin": { "type": ["string", "null"] },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": ["string", "null"], "format": "date-time" },
        "mergedAt": { "type": ["string", "null"], "format": "date-time" },
        "base": { "$ref": "#/$defs/GitHubPullRequestRef" },
        "head": { "$ref": "#/$defs/GitHubPullRequestRef" },
        "mergeCommitOid": { "type": ["string", "null"] },
        "commits": { "type": "array", "items": { "$ref": "#/$defs/GitHubPullRequestCommit" } }
      },
      "required": ["host", "nameWithOwner", "number", "title", "body", "state", "isDraft", "authorLogin", "url", "createdAt", "updatedAt", "closedAt", "mergedAt", "base", "head", "mergeCommitOid", "commits"]
    },
    "GitHubPullRequestCommitDiffParams": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "oid": { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" },
        "remote": { "type": "string", "minLength": 1, "maxLength": 255 },
        "nameWithOwner": { "type": "string", "minLength": 3, "maxLength": 140 }
      }, "required": ["number", "oid"]
    },
    "GitHubFileStatus": { "enum": ["added", "removed", "modified", "renamed", "copied", "changed", "unchanged"] },
    "GitHubPatchState": { "enum": ["available", "unavailable"] },
    "GitHubCommitFileDiff": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "oldPath": { "type": "string" }, "newPath": { "type": "string" },
        "status": { "$ref": "#/$defs/GitHubFileStatus" },
        "additions": { "type": "integer", "minimum": 0 }, "deletions": { "type": "integer", "minimum": 0 }, "changes": { "type": "integer", "minimum": 0 },
        "patchState": { "$ref": "#/$defs/GitHubPatchState" },
        "hunks": { "type": "array", "items": { "$ref": "#/$defs/DiffHunk" } }
      }, "required": ["oldPath", "newPath", "status", "additions", "deletions", "changes", "patchState", "hunks"]
    },
    "GitHubPullRequestCommitDiff": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "host": { "const": "github.com" }, "nameWithOwner": { "type": "string" }, "pullRequestNumber": { "type": "integer", "minimum": 1 },
        "commit": { "$ref": "#/$defs/GitHubPullRequestCommit" },
        "files": { "type": "array", "items": { "$ref": "#/$defs/GitHubCommitFileDiff" } }
      }, "required": ["host", "nameWithOwner", "pullRequestNumber", "commit", "files"]
    },
    "SquashTraceClassification": { "enum": ["notMerged", "originalCommit", "mergeCommit", "squashCandidate", "unresolved"] },
    "SquashTraceConfidence": { "enum": ["none", "medium", "high"] },
    "SquashTraceLocalAvailability": { "enum": ["notInspected", "available", "missing"] },
    "SquashTraceEvidence": { "enum": ["providerNotMerged", "providerMergeOidMissing", "mergeOidMatchesOriginalCommit", "mergeOidDistinctFromOriginalCommits", "localCommitAvailable", "localCommitMissing", "localCommitHasAtMostOneParent", "localCommitHasMultipleParents", "providerMergeStrategyUnavailable"] },
    "SquashTraceRelationship": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "classification": { "$ref": "#/$defs/SquashTraceClassification" },
        "confidence": { "$ref": "#/$defs/SquashTraceConfidence" },
        "mergeCommitOid": { "type": ["string", "null"] },
        "localAvailability": { "$ref": "#/$defs/SquashTraceLocalAvailability" },
        "localParentOids": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/SquashTraceEvidence" } }
      }, "required": ["classification", "confidence", "mergeCommitOid", "localAvailability", "localParentOids", "evidence"]
    },
    "GitHubSquashTrace": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "pullRequest": { "$ref": "#/$defs/GitHubPullRequest" },
        "relationship": { "$ref": "#/$defs/SquashTraceRelationship" }
      }, "required": ["pullRequest", "relationship"]
    }
  }
}
