{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitnova.dev/schema/protocol/1.7/gitnova-protocol.schema.json",
  "title": "GitNova Core Protocol 1.7",
  "type": "object",
  "properties": { "protocolVersion": { "const": "1.7" } },
  "required": ["protocolVersion"],
  "$defs": {
    "RequestId": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
    "ImplementationInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "name": { "type": "string" }, "version": { "type": "string" } },
      "required": ["name", "version"]
    },
    "ClientCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "cancellation": { "type": "boolean", "default": false } }
    },
    "ServerCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cancellation": { "type": "boolean" },
        "repositoryDiscovery": { "type": "boolean" },
        "workingTreeStatus": { "type": "boolean" },
        "structuredFileDiff": { "type": "boolean" },
        "paginatedCommitHistory": { "type": "boolean" },
        "structuredCommitDiff": { "type": "boolean" },
        "repositoryReferences": { "type": "boolean" },
        "commitGraphProjection": { "type": "boolean" }
      },
      "required": ["cancellation", "repositoryDiscovery", "workingTreeStatus", "structuredFileDiff", "paginatedCommitHistory", "structuredCommitDiff", "repositoryReferences", "commitGraphProjection"]
    },
    "InitializeParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clientInfo": { "$ref": "#/$defs/ImplementationInfo" },
        "protocolVersion": { "type": "string" },
        "capabilities": { "$ref": "#/$defs/ClientCapabilities" }
      },
      "required": ["clientInfo", "protocolVersion"]
    },
    "InitializeResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coreInfo": { "$ref": "#/$defs/ImplementationInfo" },
        "protocolVersion": { "type": "string" },
        "capabilities": { "$ref": "#/$defs/ServerCapabilities" }
      },
      "required": ["coreInfo", "protocolVersion", "capabilities"]
    },
    "CancelParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "id": { "$ref": "#/$defs/RequestId" } },
      "required": ["id"]
    },
    "ErrorData": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stableCode": { "type": "string" },
        "retryable": { "type": "boolean" },
        "details": { "type": "object", "additionalProperties": true }
      },
      "required": ["stableCode", "retryable"]
    },
    "RepositoryPathParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "path": { "type": "string", "minLength": 1 } },
      "required": ["path"]
    },
    "RepositoryKind": {
      "enum": ["worktree", "linkedWorktree", "bare"]
    },
    "RepositoryDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "worktreeRoot": { "type": ["string", "null"] },
        "gitDirectory": { "type": "string" },
        "commonGitDirectory": { "type": "string" },
        "kind": { "$ref": "#/$defs/RepositoryKind" },
        "gitVersion": { "type": "string" }
      },
      "required": ["worktreeRoot", "gitDirectory", "commonGitDirectory", "kind", "gitVersion"]
    },
    "StatusEntryKind": {
      "enum": ["ordinary", "renameOrCopy", "unmerged", "untracked"]
    },
    "FileStatus": {
      "enum": ["unmodified", "modified", "added", "deleted", "renamed", "copied", "unmerged", "untracked", "typeChanged", "unknown"]
    },
    "StatusEntry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "originalPath": { "type": ["string", "null"] },
        "kind": { "$ref": "#/$defs/StatusEntryKind" },
        "indexStatus": { "$ref": "#/$defs/FileStatus" },
        "worktreeStatus": { "$ref": "#/$defs/FileStatus" }
      },
      "required": ["path", "originalPath", "kind", "indexStatus", "worktreeStatus"]
    },
    "BranchStatus": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "head": { "type": ["string", "null"] },
        "oid": { "type": ["string", "null"] },
        "upstream": { "type": ["string", "null"] },
        "ahead": { "type": "integer", "minimum": 0 },
        "behind": { "type": "integer", "minimum": 0 }
      },
      "required": ["head", "oid", "upstream", "ahead", "behind"]
    },
    "WorkingTreeStatus": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "branch": { "$ref": "#/$defs/BranchStatus" },
        "entries": { "type": "array", "items": { "$ref": "#/$defs/StatusEntry" } }
      },
      "required": ["branch", "entries"]
    },
    "DiffScope": { "enum": ["workingTree", "staged"] },
    "DiffParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/DiffScope" },
        "contextLines": { "type": "integer", "minimum": 0, "maximum": 20 }
      },
      "required": ["path", "scope"]
    },
    "DiffLineKind": { "enum": ["context", "addition", "deletion"] },
    "DiffLine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "$ref": "#/$defs/DiffLineKind" },
        "content": { "type": "string" },
        "oldLine": { "type": ["integer", "null"], "minimum": 0 },
        "newLine": { "type": ["integer", "null"], "minimum": 0 }
      },
      "required": ["kind", "content", "oldLine", "newLine"]
    },
    "DiffHunk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oldStart": { "type": "integer", "minimum": 0 },
        "oldLines": { "type": "integer", "minimum": 0 },
        "newStart": { "type": "integer", "minimum": 0 },
        "newLines": { "type": "integer", "minimum": 0 },
        "header": { "type": "string" },
        "lines": { "type": "array", "items": { "$ref": "#/$defs/DiffLine" } }
      },
      "required": ["oldStart", "oldLines", "newStart", "newLines", "header", "lines"]
    },
    "FileDiff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oldPath": { "type": "string" },
        "newPath": { "type": "string" },
        "isBinary": { "type": "boolean" },
        "hunks": { "type": "array", "items": { "$ref": "#/$defs/DiffHunk" } }
      },
      "required": ["oldPath", "newPath", "isBinary", "hunks"]
    },
    "HistoryParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limit": { "type": "integer", "minimum": 1, "maximum": 200 },
        "cursor": { "type": "string", "minLength": 1 }
      }
    },
    "CommitIdentity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "timestamp"]
    },
    "CommitSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oid": { "type": "string" },
        "parents": { "type": "array", "items": { "type": "string" } },
        "author": { "$ref": "#/$defs/CommitIdentity" },
        "committer": { "$ref": "#/$defs/CommitIdentity" },
        "summary": { "type": "string" },
        "message": { "type": "string" }
      },
      "required": ["oid", "parents", "author", "committer", "summary", "message"]
    },
    "HistoryPage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commits": { "type": "array", "items": { "$ref": "#/$defs/CommitSummary" } },
        "nextCursor": { "type": ["string", "null"] }
      },
      "required": ["commits", "nextCursor"]
    },
    "CommitDiffParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oid": { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" },
        "parentOid": { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" },
        "contextLines": { "type": "integer", "minimum": 0, "maximum": 20 }
      },
      "required": ["oid"]
    },
    "CommitDiff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commit": { "$ref": "#/$defs/CommitSummary" },
        "parentOid": { "type": ["string", "null"] },
        "files": { "type": "array", "items": { "$ref": "#/$defs/FileDiff" } }
      },
      "required": ["commit", "parentOid", "files"]
    },
    "ReferenceKind": {
      "enum": ["localBranch", "remoteBranch", "tag"]
    },
    "RepositoryHead": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oid": { "type": ["string", "null"] },
        "symbolicRef": { "type": ["string", "null"] }
      },
      "required": ["oid", "symbolicRef"]
    },
    "RepositoryReference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "fullName": { "type": "string" },
        "kind": { "$ref": "#/$defs/ReferenceKind" },
        "targetOid": { "type": "string" },
        "peeledTargetOid": { "type": ["string", "null"] },
        "symbolicTarget": { "type": ["string", "null"] },
        "upstream": { "type": ["string", "null"] }
      },
      "required": ["name", "fullName", "kind", "targetOid", "peeledTargetOid", "symbolicTarget", "upstream"]
    },
    "RepositoryReferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "head": { "$ref": "#/$defs/RepositoryHead" },
        "references": { "type": "array", "items": { "$ref": "#/$defs/RepositoryReference" } }
      },
      "required": ["head", "references"]
    },
    "CommitGraphNode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commit": { "$ref": "#/$defs/CommitSummary" },
        "isHead": { "type": "boolean" },
        "references": { "type": "array", "items": { "$ref": "#/$defs/RepositoryReference" } }
      },
      "required": ["commit", "isHead", "references"]
    },
    "CommitGraphPage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/CommitGraphNode" } },
        "nextCursor": { "type": ["string", "null"] }
      },
      "required": ["nodes", "nextCursor"]
    }
  }
}
